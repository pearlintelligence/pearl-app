# =============================================================================
# Pearl App — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with VITE_ are exposed to the browser client.
# Variables without VITE_ are server-side only (Convex backend, build tools).
# =============================================================================

# ---------------------------------------------------------------------------
# Convex
# ---------------------------------------------------------------------------
# Convex deployment URL (set by `npx convex dev` or init_app_project tool)
VITE_CONVEX_URL=

# Convex deploy key (for CI/CD deployments, not needed for local dev)
# CONVEX_DEPLOY_KEY=

# Convex site URL (used by auth config for OAuth callbacks)
# CONVEX_SITE_URL=

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# RSA 2048 private key for auth token signing (base64-encoded)
# Generated automatically during setup; decode with the app's helper
# AUTH_PRIVATE_KEY=

# RSA 2048 private key for JWT signing (base64-encoded, optional)
# JWT_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Sentry (error monitoring)
# ---------------------------------------------------------------------------
# Client-side DSN — enables error reporting in the browser
# VITE_SENTRY_DSN=

# Build-time Sentry config for source map uploads (CI only)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Vercel (auto-injected in Vercel deployments)
# ---------------------------------------------------------------------------
# Git commit SHA — used for Sentry release tagging
# VITE_VERCEL_GIT_COMMIT_SHA=

# Set to "true" on preview deployments to enable test-user login
# VITE_IS_PREVIEW=

# ---------------------------------------------------------------------------
# Viktor Spaces (internal tooling integration)
# ---------------------------------------------------------------------------
# VIKTOR_SPACES_API_URL=
# VIKTOR_SPACES_PROJECT_NAME=
# VIKTOR_SPACES_PROJECT_SECRET=
